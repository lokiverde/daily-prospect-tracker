# Supabase Configuration
# Get these from your Supabase project: Dashboard > Settings > API

# Project URL (e.g., https://abc123.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# anon (public) key - safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role (secret) key - server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo Mode (optional - set to "true" on demo deployments only)
NEXT_PUBLIC_DEMO_MODE=false

# Consulting CTA URL (optional - shown in demo mode)
NEXT_PUBLIC_CONSULTING_CTA_URL=https://calendly.com/techtony/30min
